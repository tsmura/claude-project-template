{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.npm",
        "~/.pnpm-store",
        "~/.bun"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(docker compose *)",
      "Bash(docker ps *)",
      "Bash(docker build *)",
      "Bash(docker logs *)"
    ]
  }
}

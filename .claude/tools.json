{
  "tools": {
    "file_read": {
      "description": "Read files from the repository",
      "allowed_paths": ["src/", "tests/", "docs/", ".claude/"],
      "agents": ["all"]
    },
    "file_edit": {
      "description": "Create or modify files",
      "allowed_paths": ["src/", "tests/", "docs/"],
      "agents": ["implementer", "tester", "documenter"]
    },
    "bash": {
      "description": "Run shell commands",
      "allowed_commands": ["npm", "python", "pytest", "eslint", "git status", "git diff"],
      "blocked_commands": ["rm -rf", "curl", "wget"],
      "agents": ["implementer", "tester"]
    },
    "search": {
      "description": "Search within the codebase",
      "agents": ["all"]
    },
    "web_search": {
      "description": "Search the web for documentation and solutions",
      "agents": ["implementer", "orchestrator"]
    }
  }
}
